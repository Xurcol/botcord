{
  "name": "botcord",
  "version": "1.0.7",
  "description": "Discord client powered by a bot token",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "publish:github": "electron-builder --win --publish always"
  },
  "keywords": [],
  "author": "xurco",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Xurcol/botcord.git"
  },
  "type": "commonjs",
  "build": {
    "appId": "com.xurco.botcord",
    "productName": "BotCord",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BotCord"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "icon.ico",
      "icon.png",
      "logo.webp",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/@discordjs/opus/**",
      "node_modules/sodium-native/**"
    ],
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "Xurcol",
        "repo": "botcord",
        "private": false,
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.2",
    "discord.js": "^14.26.4",
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.3.0",
    "opusscript": "^0.0.8",
    "sodium-native": "^5.1.0"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "sharp": "^0.35.2"
  }
}
